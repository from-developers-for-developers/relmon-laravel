{
    "name": "from-developers-for-developers/relmon-laravel",
    "description": "Laravel binding for RelMon PHP SDK",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Dmitrijs Abrosimovs",
            "email": "abrosimovs@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "from-developers-for-developers/relmon-php-sdk": "^1.0@beta",
        "illuminate/contracts": "^10.0|^11.0|^12.0",
        "illuminate/database": "^10.0|^11.0|^12.0",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/validation": "^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "laravel/framework": "^10.0",
        "orchestra/testbench": "^8.0",
        "php-parallel-lint/php-parallel-lint": "^1.4",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^10.5",
        "squizlabs/php_codesniffer": "^3.10"
    },
    "autoload": {
        "psr-4": {
            "FromDevelopersForDevelopers\\RelMonLaravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "FromDevelopersForDevelopers\\RelMonLaravel\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "analyse": "phpstan analyse --configuration=phpstan.neon.dist --memory-limit=512M --debug",
        "cs": "phpcs",
        "cs-fix": "phpcbf",
        "lint": "vendor/bin/parallel-lint -p php --exclude vendor src tests",
        "quality": [
            "@lint",
            "@analyse"
        ],
        "test": "vendor/bin/phpunit",
        "test:coverage": "vendor/bin/phpunit --coverage-text",
        "check:composer": "composer validate --strict"
    },
    "extra": {
        "laravel": {
            "providers": [
                "FromDevelopersForDevelopers\\RelMonLaravel\\RelMonServiceProvider"
            ],
            "aliases": {
                "RelMon": "FromDevelopersForDevelopers\\RelMonLaravel\\Facades\\RelMon"
            }
        }
    },
    "config": {
        "sort-packages": true
    }
}
